# ── Content Laboratory — Environment Variables ───────────────────────
# Copy to repo root:  cp infra/.env.example .env  (never commit .env)
#
# Loaded by:
#   • Docker Compose  (infra/docker-compose.yml)
#   • Python shared settings  (packages/shared/py — pydantic-settings)
# ─────────────────────────────────────────────────────────────────────

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=contentlab
POSTGRES_PASSWORD=contentlab
POSTGRES_DB=contentlab

# SQLAlchemy async URL used by the API and worker (host port matches docker-compose postgres publish)
DATABASE_URL=postgresql+psycopg://contentlab:contentlab@localhost:5433/contentlab

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO (S3-compatible object store) ───────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=content-lab

# ── External APIs (never commit real keys) ───────────────────────────
RUNWAY_API_KEY=changeme
# Use https://api.runwayml.com if your key is for production (default is Runway dev API).
# RUNWAY_API_BASE_URL=https://api.dev.runwayml.com
# RUNWAY_API_VERSION=2024-11-06
